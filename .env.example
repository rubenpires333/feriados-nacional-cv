# Configurações da Aplicação
APP_NAME=feriados-nacionais-cv
APP_VERSION=1.0.0
SERVER_PORT=8083

# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=feriados_nacionais
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Configurações JPA/Hibernate
JPA_DDL_AUTO=create-drop
JPA_SHOW_SQL=true

# Configurações de Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_HIBERNATE=DEBUG

# Configurações do DevTools (desenvolvimento)
DEVTOOLS_RESTART_ENABLED=true
DEVTOOLS_LIVERELOAD_ENABLED=true

# Configurações de Segurança
JWT_SECRET=5be86359073c434bad2da3932222dabe
JWT_EXPIRATION=86400000

